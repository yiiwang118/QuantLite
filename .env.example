# Quant Lite - 环境变量
# 本文件 commit 进 git；真实密钥放 .env（gitignore）

# 服务监听
# 默认绑定 0.0.0.0:8001（小团队公网访问场景）
HOST=0.0.0.0
PORT=8001

# 用户配置文件（HTTP Basic Auth）
USERS_YAML=users.yaml

# 数据
DATA_CACHE_DIR=data_cache
QUANT_DB=quant.db
INITIAL_START_DATE=2018-01-01

# 日志
LOG_LEVEL=INFO

# 跨域（前端调试时可放开）
CORS_ALLOW_ORIGINS=*

# AI 模块（NL → DSL）
# 可选：anthropic / openai / none
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
